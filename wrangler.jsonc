{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cloudflare-do-blog-post",
  "compatibility_date": "2026-07-09",
  "observability": {
    "enabled": true,
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "CART_DO",
        "class_name": "CartDO",
      },
    ],
  },
  "main": "@tanstack/react-start/server-entry",
  "compatibility_flags": ["nodejs_compat"],
}
