{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cloudflare-do-blog-post",
  "compatibility_date": "2026-07-09",
  "observability": {
    "enabled": true,
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "CART_DO",
        "class_name": "CartDO",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["CartDO"],
    },
  ],
  "main": "src/server.ts",
  "compatibility_flags": ["nodejs_compat"],
}
